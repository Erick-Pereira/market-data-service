# Copie para .env ao correr Simcag.MarketDataService.Api (DotNetEnv).

# PostgreSQL (use POSTGRES_CONNECTION OU DB__* — POSTGRES_CONNECTION tem precedência)
# POSTGRES_CONNECTION=Host=localhost;Port=5432;Database=simcag_market_data;Username=postgres;Password=postgres
DB__HOST=localhost
DB__PORT=5432
DB__NAME=simcag_market_data
DB__USER=postgres
DB__PASSWORD=postgres

# Redis (default no código se omitir: localhost:6379)
# A API usa AbortOnConnectFail=false — sobe mesmo sem Redis (cache desativado até conectar).
# REDIS_CONNECTION=localhost:6379

# Coleta externa (workers / HTTP clients)
# EXTERNAL_API_URL=https://example.com

# Publica eventos em Redis no canal "market-data-updated-events" (payload JSON)
# PUBLISH_MARKET_DATA_EVENTS=true

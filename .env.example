# Copie para .env ao correr Simcag.MarketDataService.Api (DotNetEnv).



# PostgreSQL (padrão): ConnectionStrings__DefaultConnection

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=simcag_market_data;Username=postgres;Password=postgres

# Aliases legados (vão ser removidos): POSTGRES_CONNECTION, DB__*



# Redis (default no código se omitir: localhost:6379)
# Suba com: docker compose -f docker-compose.dev.yml up -d
# Ou use o script: .\scripts\run-all-services.ps1  (infra + SearXNG + APIs)

# A API usa AbortOnConnectFail=false — sobe mesmo sem Redis (cache desativado até conectar).

# REDIS__CONNECTION=localhost:6379



# --- Pesquisa de preços (sem mock) ---

# Recomendado: SearXNG self-hosted (open source, sem assinatura). Sobe com:
#   docker compose -f docker-compose.dev.yml up -d searxng
# UI/API: http://localhost:8088  |  JSON: /search?q=...&format=json

# MARKET_DATA__SEARXNG_BASE_URL=http://localhost:8088
# MARKET_DATA__ENABLE_SEARXNG_SCRAPE=true
# MARKET_DATA__SEARXNG_CONNECT_TIMEOUT_SECONDS=2
# MARKET_DATA__SEARXNG_COOLDOWN_MINUTES=5

# Benchmarks curados por categoria (sem API paga) quando web falha ou retorna valores implausíveis
# MARKET_DATA__ENABLE_CURATED_BENCHMARK=true

# Fallback HTML direto (DDG/Bing) quando SearXNG indisponível — gratuito mas sujeito a anti-bot (HTTP 202).

# Scraping: DuckDuckGo lite + HTML e Bing são agregados (mais amostras) antes da mediana. GET /api/market-data/price?declaredReferenceBrl= grava referência da linha
# em MarketPrices/MarketPriceHistory quando a web não devolve BRL (o price-analysis envia o valor da linha).

# Desligue explicitamente com false/0/off se não quiser esse tráfego.

# MARKET_DATA__ENABLE_DDG_LITE_SCRAPE=true

# MARKET_DATA__ENABLE_BING_HTML_SCRAPE=true

# MARKET_DATA__ENABLE_BING_RSS_SCRAPE=true

# MARKET_DATA__HTTP_TIMEOUT_SECONDS=25

# Amostras mínimas (scraping agregado DDG+Bing) e tolerância de dispersão (max−min)/mediana.

# MARKET_DATA__MINIMUM_PRICE_SAMPLES_WEB_SCRAPE=1

# MARKET_DATA__MAX_RELATIVE_SPREAD_WEB_SCRAPE=2.5

# Retentativas HTTP por provider (202 Accepted, 5xx, 429, timeout de cliente).
# MARKET_DATA__SCRAPE_MAX_RETRIES=2
# MARKET_DATA__SCRAPE_RETRY_BASE_MS=400

# Exige ≥2 preços distintos no agregado HTML antes de aceitar mediana (menos falsos positivos; Serp shopping não aplica).
# MARKET_DATA__REQUIRE_DISTINCT_SAMPLES_WEB_SCRAPE=false



# Opcional — fallback PAGO (desligado por defeito). Só ative se aceitar assinatura SerpAPI:
# MARKET_DATA__ENABLE_SERPAPI=false
# MARKET_DATA__SERPAPI_API_KEY=



# Publica eventos em Redis no canal "market-data-updated-events" (payload JSON)

# PUBLISH_MARKET_DATA_EVENTS=true

# RabbitMQ (RPC: price-analysis → get-price; **obrigatório** — mesmo broker que price-analysis/ai/ingestion)
RABBITMQ__HOST=potato-server
RABBITMQ__PORT=5672
RABBITMQ__USERNAME=admin
RABBITMQ__PASSWORD=admin
RABBITMQ__VIRTUALHOST=/

